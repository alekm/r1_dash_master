{
  "title": "Network Intelligence",
  "time_range": "Last week",
  "rows": [
    [
      {"type": "bignum", "dataset": "mlisa-apConnectionStats", "title": "Connection Success Rate", "width": 3,
       "metric": {"sql": "1.0 * SUM(successCount) / SUM(attemptCount)", "label": "Success Rate"}, "format": ".1%"},
      {"type": "bignum", "dataset": "binnedSessions", "title": "Total Traffic", "width": 3, "metric": "User Traffic (Total)"},
      {"type": "bignum", "dataset": "binnedSessions", "title": "Unique Clients", "width": 3, "metric": "Unique Client MAC Count"},
      {"type": "bignum", "dataset": "sessionsSummary", "title": "Avg Session Duration", "width": 3, "metric": "Avg Session Duration"}
    ],
    [
      {"_comment": "Venue table near the TOP: click a venue to cross-filter the whole dashboard.",
       "type": "table", "dataset": "binnedSessions", "title": "Venues - Traffic & Clients (click to filter)", "width": 12,
       "groupby": ["zoneName"], "metrics": ["User Traffic (Total)", "Unique Client MAC Count"],
       "percent_of_total": ["User Traffic (Total)"], "row_limit": 25}
    ],
    [
      {"type": "line", "dataset": "mlisa-apConnectionStats", "title": "Connection Attempts - Success vs Failure", "width": 6,
       "metrics": ["Success Count", "Failure Count"]},
      {"type": "line", "dataset": "mlisa-apConnectionStats", "title": "Connection Success Rate Over Time", "width": 6,
       "metrics": [{"sql": "1.0 * SUM(successCount) / SUM(attemptCount)", "label": "Success Rate"}], "format": ".1%"}
    ],
    [
      {"type": "table", "dataset": "binnedAvc", "title": "Top Apps by Traffic w/ Share", "width": 8,
       "groupby": ["app"], "metrics": ["Traffic (Total)"], "percent_of_total": ["Traffic (Total)"], "row_limit": 15},
      {"type": "pie", "dataset": "binnedAvc", "title": "Traffic by Category", "width": 4,
       "metric": "Traffic (Total)", "groupby": ["category"]}
    ],
    [
      {"type": "bar", "dataset": "binnedSessions", "title": "Throughput by Band (stacked)", "width": 6,
       "metrics": ["User Traffic (Total)"], "groupby": ["radio"], "stacked": true},
      {"type": "heatmap", "dataset": "binnedSessions", "title": "Traffic Heatmap (venue x time)", "width": 6,
       "metric": "User Traffic (Total)", "groupby": ["zoneName"]}
    ]
  ]
}
