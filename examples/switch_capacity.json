{
  "title": "Switch Capacity",
  "time_range": "Last week",
  "rows": [
    [
      {"type": "bignum", "dataset": "switchInventory", "title": "Total Switches", "width": 3, "metric": "Total Switches"},
      {"type": "bignum", "dataset": "switchInventory", "title": "Avg MAC Utilization", "width": 3,
       "metric": {"sql": "1.0 * SUM(macUtilization) / SUM(debug_count) / 100.0", "label": "MAC Utilization"}, "format": ".1%"},
      {"type": "bignum", "dataset": "switchInventory", "title": "Avg ARP Utilization", "width": 3, "metric": "ARP Utilization (%)"},
      {"type": "bignum", "dataset": "switchInventory", "title": "Avg IPv4 Unicast Utilization", "width": 3, "metric": "IPv4 Unicast Utilization (%)"}
    ],
    [
      {"type": "table", "dataset": "switchInventory", "title": "Capacity by Venue (click to filter)", "width": 12,
       "groupby": ["switchGroupLevelOneName"],
       "metrics": [
         "Switch Count",
         {"sql": "1.0 * SUM(macUtilization) / SUM(debug_count) / 100.0", "label": "MAC Utilization"},
         "ARP Utilization (%)", "IPv4 Unicast Utilization (%)", "IPv6 Unicast Utilization (%)", "IPv4 Multicast Utilization (%)", "IPv6 Multicast Utilization (%)"],
       "column_formats": {"MAC Utilization": ".1%"},
       "row_limit": 25}
    ],
    [
      {"type": "table", "dataset": "switchInventory", "title": "Table Utilization by Switch", "width": 12,
       "groupby": ["switchGroupLevelOneName", "switchName", "switchModel"],
       "metrics": [
         {"sql": "1.0 * SUM(macUtilization) / SUM(debug_count) / 100.0", "label": "MAC Utilization"},
         "ARP Utilization (%)", "IPv4 Unicast Utilization (%)", "IPv6 Unicast Utilization (%)", "IPv4 Multicast Utilization (%)", "IPv6 Multicast Utilization (%)"],
       "column_formats": {"MAC Utilization": ".1%"},
       "row_limit": 100}
    ],
    [
      {"type": "bar", "dataset": "switchInventory", "title": "Top Switches by MAC Utilization", "width": 6,
       "x": "switchName", "metrics": [{"sql": "1.0 * SUM(macUtilization) / SUM(debug_count) / 100.0", "label": "MAC Utilization"}], "format": ".1%", "row_limit": 15},
      {"type": "bar", "dataset": "switchInventory", "title": "Top Switches by ARP Utilization", "width": 6,
       "x": "switchName", "metrics": ["ARP Utilization (%)"], "format": ".2%", "row_limit": 15}
    ]
  ]
}
